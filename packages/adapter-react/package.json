{
  "name": "@better-pwa/adapter-react",
  "version": "1.1.0",
  "description": "React hooks and providers for better-pwa — usePwaState(), usePwaUpdate()",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.0",
    "typescript": "^5.7",
    "tsup": "^8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMilord/better-pwa",
    "directory": "packages/adapter-react"
  },
  "keywords": [
    "react",
    "hooks",
    "pwa",
    "state-management"
  ]
}
