{
  "name": "better-pwa",
  "version": "1.0.1",
  "description": "CLI for better-pwa: project scaffolding, SW building, diagnostics, auditing, and simulation",
  "type": "module",
  "bin": {
    "better-pwa": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "publishConfig": { "access": "public" },
  "files": ["dist/", "package.json", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "tsup": "^8.0"
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMilord/better-pwa",
    "directory": "packages/cli"
  },
  "keywords": ["cli", "pwa", "scaffolding", "diagnostics"]
}
