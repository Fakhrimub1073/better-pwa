{
  "name": "@better-pwa/manifest",
  "version": "1.1.0",
  "description": "Web app manifest generation with automatic icon pipeline and HTML link tag creation for PWAs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "tsup": "^8.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMilord/better-pwa",
    "directory": "packages/manifest"
  },
  "keywords": [
    "manifest",
    "pwa",
    "web-app-manifest",
    "icons"
  ]
}
